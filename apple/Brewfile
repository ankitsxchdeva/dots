# Brewfile — `brew bundle --file=apple/Brewfile`
#
# ─────────────────────────────────────────────────────────────────────
#  Two sections:
#
#    1. REQUIRED — the bare-minimum tools the dotfiles actually configure.
#       With these installed, every stowed config (zsh/ git/ tmux/ vim/
#       ghostty/ lazygit/) works as intended. Keep them on every machine.
#
#    2. OPTIONAL — everything else, commented out. `brew bundle` ignores
#       commented lines, so a fresh `brew bundle` installs ONLY the
#       required set. Uncomment per machine (personal vs work), or just
#       `brew install <name>` ad-hoc.
#
#  Each REQUIRED item notes inline which dotfile depends on it.
# ─────────────────────────────────────────────────────────────────────


# ═══ REQUIRED ════════════════════════════════════════════════════════

# ── Install mechanism ────────────────────────────────────────────────
brew "stow"           # install.sh symlinks every dotfile with this
brew "git"            # the repo IS a git config; bootstrap/install clone with it
brew "gh"             # .gitconfig credential helper hard-codes /opt/homebrew/bin/gh

# ── Shell experience (.zshrc / .zprofile wire these up) ──────────────
brew "fzf"            # sourced (fzf --zsh) + Nord theme + Ctrl-R/Ctrl-T binds
brew "ripgrep"        # rg — FZF_DEFAULT_COMMAND + fast grep
brew "bat"            # cat alias, MANPAGER, BAT_THEME=Nord
brew "eza"            # ls/la/ll/lt/tree aliases (needs a Nerd Font for --icons)
brew "zoxide"         # smarter cd (z)
brew "git-delta"      # .gitconfig pager + diffFilter (syntax-theme Nord)
brew "lazygit"        # `lg` alias + stowed lazygit/config.yml (Nord TUI)

# ── Editor & multiplexer (dedicated stowed configs) ──────────────────
brew "vim"            # $EDITOR + stowed .vimrc
brew "tmux"           # stowed .tmux.conf

# ── Terminal & font ──────────────────────────────────────────────────
cask "ghostty"                  # the terminal these dotfiles theme (ghostty/config)
                                #   ↳ drop this if the machine uses another terminal
cask "font-fira-code-nerd-font" # ghostty font-family + eza/lazygit nerd-font glyphs


# ═══ OPTIONAL — uncomment per machine ════════════════════════════════
# Nothing below is needed for the dotfiles to function.

