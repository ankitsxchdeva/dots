#!/usr/bin/env bash
# pre-commit — refuse to commit secrets or internal-only strings.
# install.sh symlinks this into .git/hooks/pre-commit. Bypass a false positive
# with:  git commit --no-verify
set -u

patt='-----BEGIN [A-Z ]*PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|xox[baprs]-[0-9A-Za-z-]+|(password|secret|api[_-]?key)[[:space:]]*[:=]'

# Work/personal-specific strings live in ~/.git-deny-patterns (one per line,
# never tracked) so this hook stays publishable.
if [ -f ~/.git-deny-patterns ]; then
  extra=$(grep -v '^[[:space:]]*$' ~/.git-deny-patterns | paste -sd'|' -)
  [ -n "$extra" ] && patt="$patt|$extra"
fi

# Inspect only ADDED lines (^+, not the +++ header).
hits=$(git diff --cached -U0 --no-color \
        | grep -E '^\+[^+]' \
        | grep -inE -e "$patt" \
        | grep -viE 'HIST_IGNORE_SPACE|handy for secrets')

if [ -n "$hits" ]; then
  printf '\033[0;31m✗ commit blocked — staged changes look sensitive:\033[0m\n' >&2
  printf '%s\n' "$hits" | head -8 | sed 's/^/    /' >&2
  echo >&2
  echo "  Move secrets/work strings to a local-only file (*.local, ~/.server_aliases)." >&2
  echo "  False positive? Re-run with:  git commit --no-verify" >&2
  exit 1
fi
exit 0
